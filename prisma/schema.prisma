// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
// The schema defines three models: User, Budget, and Expense. Each User can have multiple Budgets, 
// and each Budget can have multiple Expenses. The relationships are defined using Prisma's relation fields. 
// The User model has a one-to-many relationship with the Budget model, 
// and the Budget model has a one-to-many relationship with the Expense model. 
// Each model has an id field that is a UUID, and timestamps for creation and updates. 
// The User model also includes fields for name, email, and password
// User model can have multiple budgets, and each budget belongs to one user
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  budgets   Budget[]
}

model Budget {
  id        String    @id @default(uuid())
  title     String
  income    Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenses  Expense[]
}

model Expense {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  category  String?
  createdAt DateTime @default(now())

  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
}

